'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';
import { useSession } from 'next-auth/react';
import LoadingSpinner from '@/components/LoadingSpinner';
import { generateCode } from '@/lib/utils';

type GameType = 'quiz' | 'uno' | 'taboo' | 'skyjow' | 'yahtzee' | 'puissance4';

const GAME_OPTIONS: { value: GameType; icon: string; label: string }[] = [
    { value: 'quiz', icon: '🎯', label: 'Quiz' },
    { value: 'uno', icon: '🃏', label: 'UNO' },
    { value: 'taboo', icon: '🗣️', label: 'Taboo' },
    { value: 'skyjow', icon: '🂠', label: 'Skyjow' },
    { value: 'yahtzee', icon: '🎲', label: 'Yahtzee' },
    { value: 'puissance4', icon: '🔘', label: 'Puissance 4' },
];

const MAX_PLAYERS_BY_GAME: Record<GameType, number[]> = {
    quiz: [2, 3, 4, 5, 6, 7, 8, 10, 12, 16, 20],
    uno: [2, 3, 4, 5, 6, 7, 8],
    taboo: [4, 5, 6, 7, 8, 10, 12],
    skyjow: [2, 3, 4, 5, 6, 7, 8],
    yahtzee: [2, 3, 4, 5, 6, 7, 8],
    puissance4: [2],
};

const DEFAULT_MAX: Record<GameType, number> = {
    quiz: 8, uno: 4, taboo: 6, skyjow: 4, yahtzee: 4, puissance4: 2,
};

function OptionRow({ label, children }: { label: string; children: React.ReactNode }) {
    return (
        <div className="flex items-center justify-between gap-4">
            <span className="text-sm text-slate-300">{label}</span>
            <div className="flex-shrink-0">{children}</div>
        </div>
    );
}

function OptionSelect({ value, onChange, options }: {
    value: number | string;
    onChange: (v: string) => void;
    options: { v: string | number; label: string }[];
}) {
    return (
        <select
            value={value}
            onChange={e => onChange(e.target.value)}
            className="bg-slate-700/60 border border-slate-600/50 rounded-lg px-3 py-1.5 text-white text-xs focus:outline-none focus:ring-2 focus:ring-blue-500/60 cursor-pointer"
        >
            {options.map(o => <option key={o.v} value={o.v} className="bg-slate-800">{o.label}</option>)}
        </select>
    );
}

function Toggle({ checked, onChange, label }: { checked: boolean; onChange: (v: boolean) => void; label: string }) {
    return (
        <div className="flex items-center justify-between gap-4">
            <span className="text-sm text-slate-300">{label}</span>
            <button
                type="button"
                onClick={() => onChange(!checked)}
                className={`relative w-10 h-5 rounded-full transition-colors flex-shrink-0 ${checked ? 'bg-blue-500' : 'bg-slate-600'}`}
            >
                <span className={`absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-white shadow transition-transform ${checked ? 'translate-x-5' : ''}`} />
            </button>
        </div>
    );
}

export default function CreateLobbyPage() {
    const { data: session, status } = useSession();
    const router = useRouter();

    // Base
    const [title, setTitle] = useState('');
    const [description, setDescription] = useState('');
    const [gameType, setGameType] = useState<GameType>('quiz');
    const [maxPlayers, setMaxPlayers] = useState(8);
    const [isPublic, setIsPublic] = useState(true);
    const [creating, setCreating] = useState(false);

    // UNO
    const [unoTeamMode, setUnoTeamMode] = useState<'none' | '2v2'>('none');
    const [unoTeamWinMode, setUnoTeamWinMode] = useState<'one' | 'both'>('one');
    const [unoStackable, setUnoStackable] = useState(false);
    const [unoJumpIn, setUnoJumpIn] = useState(false);

    // Taboo
    const [tabooTurnDuration, setTabooTurnDuration] = useState(60);
    const [tabooTotalRounds, setTabooTotalRounds] = useState(3);
    const [tabooTrapWordCount, setTabooTrapWordCount] = useState(5);
    const [tabooMaxAttempts, setTabooMaxAttempts] = useState(10);
    const [tabooTrapDuration, setTabooTrapDuration] = useState(60);

    // Quiz
    const [quizTimeMode, setQuizTimeMode] = useState<'per_question' | 'total' | 'none'>('per_question');
    const [quizTimePerQuestion, setQuizTimePerQuestion] = useState(60);

    // Skyjow
    const [skyjowEliminateRows, setSkyjowEliminateRows] = useState(false);

    if (status === 'loading') return <LoadingSpinner />;
    if (status !== 'authenticated') { router.replace('/login'); return null; }

    const username = session.user.username ?? session.user.email ?? 'Joueur';

    const handleGameTypeChange = (g: GameType) => {
        setGameType(g);
        setMaxPlayers(DEFAULT_MAX[g]);
        if (g === 'uno') setUnoTeamMode('none');
    };

    const handleUnoTeamMode = (mode: 'none' | '2v2') => {
        setUnoTeamMode(mode);
        setMaxPlayers(mode === '2v2' ? 4 : DEFAULT_MAX.uno);
    };

    const handleCreate = () => {
        if (!title.trim()) return;
        setCreating(true);
        const code = generateCode();
        sessionStorage.setItem(`lobby_meta_${code}`, JSON.stringify({
            title: title.trim(),
            description: description.trim(),
            maxPlayers,
            isPublic,
            gameType,
            unoOptions: { stackable: unoStackable, jumpIn: unoJumpIn, teamMode: unoTeamMode, teamWinMode: unoTeamWinMode },
            tabooOptions: { turnDuration: tabooTurnDuration, totalRounds: tabooTotalRounds, trapWordCount: tabooTrapWordCount, maxAttempts: tabooMaxAttempts, trapDuration: tabooTrapDuration },
            quizOptions: { timeMode: quizTimeMode, timePerQuestion: quizTimePerQuestion },
            skyjowOptions: { eliminateRows: skyjowEliminateRows },
        }));
        router.push(`/lobby/create/${code}`);
    };

    const isMaxLocked = gameType === 'puissance4' || (gameType === 'uno' && unoTeamMode === '2v2');

    return (
        <main className="min-h-screen bg-gradient-to-br from-slate-950 via-blue-950 to-slate-900 flex items-center justify-center p-4">

            <div className="pointer-events-none fixed inset-0 overflow-hidden">
                <div className="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-blue-600/10 blur-3xl" />
                <div className="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-indigo-600/10 blur-3xl" />
            </div>

            <div className="relative w-full max-w-lg py-8">

                {/* Header */}
                <div className="text-center mb-8">
                    <div className="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 shadow-lg shadow-blue-500/30 mb-4 text-3xl">
                        🎮
                    </div>
                    <h1 className="text-3xl font-bold text-white tracking-tight">Créer un lobby</h1>
                    <p className="text-slate-400 mt-1 text-sm">Configurez votre partie et invitez vos amis</p>
                </div>

                <div className="bg-slate-900/80 backdrop-blur-xl border border-slate-700/50 rounded-2xl shadow-2xl p-6 space-y-6">

                    {/* Titre */}
                    <div className="space-y-1.5">
                        <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider">
                            Titre du lobby <span className="text-blue-400">*</span>
                        </label>
                        <input
                            type="text"
                            value={title}
                            onChange={e => setTitle(e.target.value)}
                            onKeyDown={e => e.key === 'Enter' && handleCreate()}
                            placeholder={`Partie de ${username}`}
                            maxLength={60}
                            className="w-full bg-slate-800/60 border border-slate-600/50 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/60 transition-all"
                        />
                        <div className="text-right text-xs text-slate-600">{title.length}/60</div>
                    </div>

                    {/* Description */}
                    <div className="space-y-1.5">
                        <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider">
                            Description <span className="text-slate-600 font-normal normal-case">(optionnel)</span>
                        </label>
                        <textarea
                            value={description}
                            onChange={e => setDescription(e.target.value)}
                            placeholder="Décrivez votre partie, le niveau requis, vos règles maison…"
                            maxLength={200}
                            rows={2}
                            className="w-full bg-slate-800/60 border border-slate-600/50 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/60 transition-all resize-none"
                        />
                        <div className="text-right text-xs text-slate-600">{description.length}/200</div>
                    </div>

                    <div className="border-t border-slate-700/50" />

                    {/* Jeu */}
                    <div className="space-y-2">
                        <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Jeu</label>
                        <div className="grid grid-cols-3 gap-2">
                            {GAME_OPTIONS.map(g => (
                                <button key={g.value} onClick={() => handleGameTypeChange(g.value)}
                                    className={`flex flex-col items-center gap-1 py-3 px-2 rounded-xl border-2 font-semibold text-xs transition-all
                                        ${gameType === g.value
                                            ? 'border-blue-500 bg-blue-500/15 text-blue-300 shadow-sm shadow-blue-500/20'
                                            : 'border-slate-700/50 bg-slate-800/40 text-slate-400 hover:border-slate-600 hover:text-slate-300'
                                        }`}>
                                    <span className="text-xl">{g.icon}</span>
                                    <span>{g.label}</span>
                                </button>
                            ))}
                        </div>
                    </div>

                    {/* ── Options UNO ── */}
                    {gameType === 'uno' && (
                        <div className="bg-slate-800/40 rounded-xl p-4 space-y-3 border border-slate-700/30">
                            <p className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Options UNO</p>
                            <div className="grid grid-cols-2 gap-2">
                                {([{ v: 'none', label: '👤 Solo', desc: '2–8' }, { v: '2v2', label: '👥 2v2', desc: '4 joueurs' }] as const).map(opt => (
                                    <button key={opt.v} onClick={() => handleUnoTeamMode(opt.v)}
                                        className={`py-2 px-3 rounded-lg border-2 text-xs font-semibold transition-all flex flex-col items-center
                                            ${unoTeamMode === opt.v ? 'border-blue-500 bg-blue-500/15 text-blue-300' : 'border-slate-600/50 text-slate-400 hover:border-slate-500'}`}>
                                        <span>{opt.label}</span>
                                        <span className="opacity-60 font-normal">{opt.desc}</span>
                                    </button>
                                ))}
                            </div>
                            {unoTeamMode === '2v2' && (
                                <OptionRow label="Condition de victoire">
                                    <OptionSelect value={unoTeamWinMode} onChange={v => setUnoTeamWinMode(v as 'one' | 'both')} options={[
                                        { v: 'one', label: 'Un vide sa main' },
                                        { v: 'both', label: 'Les 2 vident leur main' },
                                    ]} />
                                </OptionRow>
                            )}
                            <Toggle checked={unoStackable} onChange={setUnoStackable} label="Cartes empilables (+2/+4)" />
                            {unoTeamMode !== '2v2' && (
                                <Toggle checked={unoJumpIn} onChange={setUnoJumpIn} label="Jump-in" />
                            )}
                        </div>
                    )}

                    {/* ── Options Taboo ── */}
                    {gameType === 'taboo' && (
                        <div className="bg-slate-800/40 rounded-xl p-4 space-y-3 border border-slate-700/30">
                            <p className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Options Taboo</p>
                            <OptionRow label="Durée d'un tour">
                                <OptionSelect value={tabooTurnDuration} onChange={v => setTabooTurnDuration(Number(v))}
                                    options={[15, 30, 45, 60, 90, 120, 180, 240, 300].map(t => ({ v: t, label: `${t}s` }))} />
                            </OptionRow>
                            <OptionRow label="Nombre de rounds">
                                <OptionSelect value={tabooTotalRounds} onChange={v => setTabooTotalRounds(Number(v))}
                                    options={[1, 2, 3, 4, 5, 7, 10].map(r => ({ v: r, label: `${r} round${r > 1 ? 's' : ''}` }))} />
                            </OptionRow>
                            <OptionRow label="Mots piégés">
                                <OptionSelect value={tabooTrapWordCount} onChange={v => setTabooTrapWordCount(Number(v))}
                                    options={[2, 3, 4, 5, 6, 7, 8, 10].map(n => ({ v: n, label: `${n} mots` }))} />
                            </OptionRow>
                            <OptionRow label="Temps pour trouver les mots piégés">
                                <OptionSelect value={tabooTrapDuration} onChange={v => setTabooTrapDuration(Number(v))}
                                    options={[15, 30, 45, 60, 90, 120, 180].map(t => ({ v: t, label: `${t}s` }))} />
                            </OptionRow>
                            <OptionRow label="Tentatives max par tour">
                                <OptionSelect value={tabooMaxAttempts} onChange={v => setTabooMaxAttempts(Number(v))}
                                    options={[3, 5, 7, 10, 15, 20, 30].map(n => ({ v: n, label: `${n}` }))} />
                            </OptionRow>
                        </div>
                    )}

                    {/* ── Options Quiz ── */}
                    {gameType === 'quiz' && (
                        <div className="bg-slate-800/40 rounded-xl p-4 space-y-3 border border-slate-700/30">
                            <p className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Options Quiz</p>
                            <OptionRow label="Mode de temps">
                                <OptionSelect value={quizTimeMode} onChange={v => setQuizTimeMode(v as typeof quizTimeMode)} options={[
                                    { v: 'per_question', label: 'Par question' },
                                    { v: 'total', label: 'Temps total' },
                                    { v: 'none', label: 'Sans limite' },
                                ]} />
                            </OptionRow>
                            {quizTimeMode !== 'none' && (
                                <OptionRow label={quizTimeMode === 'total' ? 'Temps total' : 'Temps / question'}>
                                    <OptionSelect value={quizTimePerQuestion} onChange={v => setQuizTimePerQuestion(Number(v))}
                                        options={(quizTimeMode === 'total'
                                            ? [60, 120, 180, 300, 600, 900, 1200, 1800, 3600]
                                            : [5, 10, 15, 20, 30, 45, 60, 90, 120]
                                        ).map(t => ({
                                            v: t,
                                            label: quizTimeMode === 'total'
                                                ? (t < 60 ? `${t}s` : `${Math.floor(t / 60)} min${t % 60 ? ` ${t % 60}s` : ''}`)
                                                : `${t}s`,
                                        }))} />
                                </OptionRow>
                            )}
                        </div>
                    )}

                    {/* ── Options Skyjow ── */}
                    {gameType === 'skyjow' && (
                        <div className="bg-slate-800/40 rounded-xl p-4 space-y-3 border border-slate-700/30">
                            <p className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Options Skyjow</p>
                            <Toggle checked={skyjowEliminateRows} onChange={setSkyjowEliminateRows} label="Éliminer les lignes (4 identiques)" />
                        </div>
                    )}

                    {/* ── Yahtzee / Puissance 4 : pas d'options ── */}
                    {(gameType === 'yahtzee' || gameType === 'puissance4') && (
                        <div className="bg-slate-800/40 rounded-xl p-3 border border-slate-700/30 text-center">
                            <p className="text-xs text-slate-500 italic">
                                {gameType === 'yahtzee' ? '🎲 Yahtzee — aucune option à configurer.' : '🔘 Puissance 4 — exactement 2 joueurs.'}
                            </p>
                        </div>
                    )}

                    <div className="border-t border-slate-700/50" />

                    {/* Joueurs max + Visibilité */}
                    <div className="grid grid-cols-2 gap-4">
                        <div className="space-y-1.5">
                            <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Joueurs max</label>
                            <select
                                value={maxPlayers}
                                onChange={e => setMaxPlayers(Number(e.target.value))}
                                disabled={isMaxLocked}
                                className="w-full bg-slate-800/60 border border-slate-600/50 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/60 transition-all appearance-none cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                            >
                                {MAX_PLAYERS_BY_GAME[gameType].map(n => (
                                    <option key={n} value={n} className="bg-slate-800">{n} joueurs</option>
                                ))}
                            </select>
                        </div>

                        <div className="space-y-1.5">
                            <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Visibilité</label>
                            <div className="flex rounded-xl border border-slate-600/50 overflow-hidden h-[46px]">
                                <button onClick={() => setIsPublic(true)}
                                    className={`flex-1 flex items-center justify-center gap-1.5 text-xs font-semibold transition-all
                                        ${isPublic ? 'bg-blue-600 text-white' : 'bg-slate-800/60 text-slate-400 hover:text-slate-300'}`}>
                                    🌍 <span>Public</span>
                                </button>
                                <button onClick={() => setIsPublic(false)}
                                    className={`flex-1 flex items-center justify-center gap-1.5 text-xs font-semibold transition-all border-l border-slate-600/50
                                        ${!isPublic ? 'bg-indigo-600 text-white' : 'bg-slate-800/60 text-slate-400 hover:text-slate-300'}`}>
                                    🔒 <span>Privé</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <p className={`text-xs rounded-lg px-3 py-2 ${isPublic ? 'bg-blue-500/10 text-blue-300 border border-blue-500/20' : 'bg-indigo-500/10 text-indigo-300 border border-indigo-500/20'}`}>
                        {isPublic
                            ? '🌍 Visible dans la liste des lobbies — n\'importe qui peut rejoindre.'
                            : '🔒 Accessible uniquement par lien direct — n\'apparaît pas dans la liste.'}
                    </p>

                    <div className="border-t border-slate-700/50" />

                    {/* Actions */}
                    <div className="flex gap-3">
                        <button onClick={() => router.back()}
                            className="px-5 py-3 rounded-xl border border-slate-600/50 text-slate-400 text-sm font-semibold hover:border-slate-500 hover:text-slate-300 transition-all">
                            Annuler
                        </button>
                        <button
                            onClick={handleCreate}
                            disabled={!title.trim() || creating}
                            className="flex-1 py-3 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 disabled:from-slate-700 disabled:to-slate-700 disabled:text-slate-500 disabled:cursor-not-allowed text-white font-bold text-sm transition-all shadow-lg shadow-blue-500/20 disabled:shadow-none"
                        >
                            {creating ? '⏳ Création…' : '🚀 Créer le lobby'}
                        </button>
                    </div>
                </div>

                <div className="text-center mt-4">
                    <button onClick={() => router.push('/lobbies')}
                        className="text-xs text-slate-500 hover:text-slate-400 transition-colors underline underline-offset-2">
                        Voir les lobbies existants
                    </button>
                </div>
            </div>
        </main>
    );
}
